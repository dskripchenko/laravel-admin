{
    "name": "dskripchenko/laravel-admin-media",
    "description": "Расширенная медиа-библиотека (коллекции, теги, focal-point, responsive-варианты) для dskripchenko/laravel-admin.",
    "license": "MIT",
    "type": "library",
    "authors": [
        { "name": "Denis Skripchenko", "email": "denskrp90@gmail.com" }
    ],
    "require": {
        "php": "^8.5",
        "ext-gd": "*",
        "dskripchenko/laravel-admin": "^1.0|@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.18"
    },
    "suggest": {
        "intervention/image": "Расширенный image processing (advanced filters, watermarks)",
        "ext-imagick": "Альтернатива GD с лучшим качеством и поддержкой большего числа форматов"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminMedia\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminMedia\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dskripchenko\\LaravelAdminMedia\\AdminMediaServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
