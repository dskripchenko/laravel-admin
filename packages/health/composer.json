{
    "name": "dskripchenko/laravel-admin-health",
    "description": "Health-checks dashboard для dskripchenko/laravel-admin (свои чекеры, без spatie/laravel-health).",
    "license": "MIT",
    "type": "library",
    "authors": [
        { "name": "Denis Skripchenko", "email": "denskrp90@gmail.com" }
    ],
    "require": {
        "php": "^8.5",
        "dskripchenko/laravel-admin": "^1.0|@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminHealth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminHealth\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dskripchenko\\LaravelAdminHealth\\AdminHealthServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
