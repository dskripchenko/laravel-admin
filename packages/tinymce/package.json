{
    "name": "@dskripchenko/laravel-admin-tinymce",
    "version": "0.1.0-dev",
    "description": "TinyMCE WYSIWYG plugin for @dskripchenko/laravel-admin.",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": ["dist", "README.md"],
    "scripts": {
        "build": "vite build && vue-tsc --emitDeclarationOnly"
    },
    "peerDependencies": {
        "@dskripchenko/laravel-admin": "*",
        "@tinymce/tinymce-vue": "^5",
        "tinymce": "^7",
        "vue": "^3.4"
    }
}
