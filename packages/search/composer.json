{
    "name": "dskripchenko/laravel-admin-search",
    "description": "Глобальный поиск (cmd+K) по Resource'ам для dskripchenko/laravel-admin.",
    "license": "MIT",
    "type": "library",
    "authors": [
        { "name": "Denis Skripchenko", "email": "denskrp90@gmail.com" }
    ],
    "require": {
        "php": "^8.5",
        "dskripchenko/laravel-admin": "^1.0|@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.18"
    },
    "suggest": {
        "laravel/scout": "Для поиска через Algolia/Meilisearch/TNTSearch/Database engine"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminSearch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminSearch\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dskripchenko\\LaravelAdminSearch\\AdminSearchServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
