{
    "name": "dskripchenko/laravel-admin-pulse",
    "description": "Лёгкая телеметрия (request/query/job/exception) для dskripchenko/laravel-admin (без laravel/pulse).",
    "license": "MIT",
    "type": "library",
    "authors": [
        { "name": "Denis Skripchenko", "email": "denskrp90@gmail.com" }
    ],
    "require": {
        "php": "^8.5",
        "dskripchenko/laravel-admin": "^1.0|@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminPulse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminPulse\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dskripchenko\\LaravelAdminPulse\\AdminPulseServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
