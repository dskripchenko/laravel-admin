{
    "name": "@dskripchenko/laravel-admin",
    "version": "0.1.0-dev",
    "description": "Vue 3 SPA bundle for dskripchenko/laravel-admin Laravel package.",
    "license": "MIT",
    "author": "Denis Skripchenko <denskrp90@gmail.com>",
    "type": "module",
    "workspaces": [
        "packages/tinymce",
        "packages/quill"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./style.css": "./dist/style.css"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build && vue-tsc --emitDeclarationOnly",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint resources/ts --ext .ts,.vue",
        "typecheck": "vue-tsc --noEmit"
    },
    "peerDependencies": {
        "@dskripchenko/ui": "*",
        "@tiptap/starter-kit": "^2.4",
        "@tiptap/vue-3": "^2.4",
        "axios": "^1.6",
        "marked": "^12.0",
        "pinia": "^2.1",
        "vue": "^3.4",
        "vue-router": "^4.3"
    },
    "devDependencies": {
        "@types/node": "^22",
        "@vitejs/plugin-vue": "^5.2.4",
        "@vue/test-utils": "^2.4.10",
        "axios": "^1.15.2",
        "axios-mock-adapter": "^2.1.0",
        "eslint": "^9",
        "eslint-plugin-vue": "^9",
        "jsdom": "^25",
        "pinia": "^3.0.4",
        "typescript": "^5.5",
        "vite": "^5",
        "vite-plugin-dts": "^4",
        "vitest": "^2",
        "vue": "^3.5.33",
        "vue-router": "^5.0.6",
        "vue-tsc": "^2"
    }
}
